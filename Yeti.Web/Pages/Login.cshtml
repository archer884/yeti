@page
@model LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<h1>Sign in</h1>

@if (Model.Error is not null)
{
    <p class="error">@Model.Error</p>
}

<form method="post">
    <p>
        <label>Username<br /><input asp-for="Username" autofocus required /></label>
    </p>
    <p>
        <label>Password<br /><input asp-for="Password" type="password" required /></label>
    </p>
    <button type="submit">Sign in</button>
</form>
